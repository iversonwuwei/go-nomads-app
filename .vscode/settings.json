{
    "java.compile.nullAnalysis.mode": "automatic",
    "java.configuration.updateBuildConfiguration": "automatic",
    
    // ==================== 文件编码设置 - 彻底防止中文乱码 ====================
    "files.encoding": "utf8",
    "files.autoGuessEncoding": false,  // 关闭自动猜测，强制使用 UTF-8
    "files.candidateGuessEncodings": [], // 清空候选编码列表
    
    // 新建文件默认使用 UTF-8
    "[*]": {
        "files.encoding": "utf8"
    },
    
    // Dart 格式化和编码设置
    "dart.lineLength": 120,
    "dart.analysisExcludedFolders": [
        "${workspaceFolder}/.dart_tool",
        "${workspaceFolder}/build",
        "${workspaceFolder}/ios/Pods",
        "${workspaceFolder}/macos/Pods",
        "${workspaceFolder}/android/.gradle",
        "${workspaceFolder}/android/build",
        "${workspaceFolder}/.openclaw"
    ],
    "files.watcherExclude": {
        "**/.dart_tool/**": true,
        "**/build/**": true,
        "**/ios/Pods/**": true,
        "**/macos/Pods/**": true,
        "**/android/.gradle/**": true,
        "**/android/build/**": true
    },
    "search.exclude": {
        "**/.dart_tool": true,
        "**/build": true,
        "**/ios/Pods": true,
        "**/macos/Pods": true,
        "**/android/.gradle": true,
        "**/android/build": true
    },
    "[dart]": {
        "files.encoding": "utf8",
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            120
        ],
        "editor.selectionHighlight": false,
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },
    "cmake.ignoreCMakeListsMissing": true
}