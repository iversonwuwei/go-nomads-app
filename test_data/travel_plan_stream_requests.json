{
  "description": "测试 /api/v1/ai/travel-plan/stream 接口的请求参数数据集",
  "base_url": "http://localhost:5000",
  "endpoint": "/api/v1/ai/travel-plan/stream",
  "test_cases": [
    {
      "id": "test-001-basic",
      "name": "基础测试 - 北京3天游",
      "description": "最小参数集，测试基础功能",
      "request": {
        "cityId": "beijing",
        "cityName": "北京",
        "cityImage": "https://example.com/beijing.jpg",
        "duration": 3,
        "budget": "medium",
        "travelStyle": "culture",
        "interests": ["历史", "美食"]
      },
      "expected": {
        "should_succeed": true,
        "has_daily_itineraries": true,
        "itinerary_count": 3
      }
    },

    {
      "id": "test-002-full-params",
      "name": "完整参数 - 上海5天游",
      "description": "包含所有可选参数",
      "request": {
        "cityId": "shanghai",
        "cityName": "上海",
        "cityImage": "https://example.com/shanghai.jpg",
        "duration": 5,
        "budget": "high",
        "travelStyle": "nightlife",
        "interests": ["购物", "美食", "现代建筑"],
        "departureLocation": "杭州",
        "customBudget": "8000",
        "currency": "CNY",
        "selectedAttractions": ["外滩", "东方明珠", "豫园"]
      },
      "expected": {
        "should_succeed": true,
        "has_daily_itineraries": true,
        "itinerary_count": 5,
        "should_include_selected_attractions": true
      }
    },

    {
      "id": "test-003-budget-low",
      "name": "低预算 - 成都2天游",
      "description": "测试低预算场景",
      "request": {
        "cityId": "chengdu",
        "cityName": "成都",
        "cityImage": "https://example.com/chengdu.jpg",
        "duration": 2,
        "budget": "low",
        "travelStyle": "relaxation",
        "interests": ["美食", "熊猫"],
        "customBudget": "1500",
        "currency": "CNY"
      },
      "expected": {
        "should_succeed": true,
        "budget_friendly": true
      }
    },

    {
      "id": "test-004-adventure",
      "name": "冒险风格 - 丽江7天游",
      "description": "测试冒险风格与长时间行程",
      "request": {
        "cityId": "lijiang",
        "cityName": "丽江",
        "cityImage": "https://example.com/lijiang.jpg",
        "duration": 7,
        "budget": "medium",
        "travelStyle": "adventure",
        "interests": ["徒步", "自然", "摄影"],
        "departureLocation": "昆明"
      },
      "expected": {
        "should_succeed": true,
        "has_daily_itineraries": true,
        "itinerary_count": 7
      }
    },

    {
      "id": "test-005-single-day",
      "name": "单日游 - 苏州1天游",
      "description": "测试最短时长（1天）",
      "request": {
        "cityId": "suzhou",
        "cityName": "苏州",
        "cityImage": "https://example.com/suzhou.jpg",
        "duration": 1,
        "budget": "medium",
        "travelStyle": "culture",
        "interests": ["园林", "历史"]
      },
      "expected": {
        "should_succeed": true,
        "itinerary_count": 1
      }
    },

    {
      "id": "test-006-max-duration",
      "name": "最长时长 - 西藏30天游",
      "description": "测试最大时长（30天）",
      "request": {
        "cityId": "lhasa",
        "cityName": "拉萨",
        "cityImage": "https://example.com/lhasa.jpg",
        "duration": 30,
        "budget": "high",
        "travelStyle": "adventure",
        "interests": ["自然", "宗教", "摄影"],
        "customBudget": "25000",
        "currency": "CNY"
      },
      "expected": {
        "should_succeed": true,
        "itinerary_count": 30
      }
    },

    {
      "id": "test-007-custom-budget-format",
      "name": "自定义预算格式 - 广州4天游",
      "description": "测试 budget 参数为 'CURRENCY:AMOUNT' 格式",
      "request": {
        "cityId": "guangzhou",
        "cityName": "广州",
        "cityImage": "https://example.com/guangzhou.jpg",
        "duration": 4,
        "budget": "CNY:6000",
        "travelStyle": "culture",
        "interests": ["美食", "历史", "购物"]
      },
      "expected": {
        "should_succeed": true,
        "should_parse_custom_budget": true
      }
    },

    {
      "id": "test-008-multiple-interests",
      "name": "多兴趣点 - 杭州3天游",
      "description": "测试大量兴趣标签",
      "request": {
        "cityId": "hangzhou",
        "cityName": "杭州",
        "cityImage": "https://example.com/hangzhou.jpg",
        "duration": 3,
        "budget": "medium",
        "travelStyle": "relaxation",
        "interests": ["自然", "历史", "茶文化", "美食", "摄影", "徒步"]
      },
      "expected": {
        "should_succeed": true,
        "should_cover_multiple_interests": true
      }
    },

    {
      "id": "test-009-international",
      "name": "国际城市 - 东京5天游",
      "description": "测试国际城市（非中文）",
      "request": {
        "cityId": "tokyo",
        "cityName": "Tokyo",
        "cityImage": "https://example.com/tokyo.jpg",
        "duration": 5,
        "budget": "high",
        "travelStyle": "culture",
        "interests": ["anime", "food", "shopping", "temples"],
        "departureLocation": "Shanghai",
        "customBudget": "15000",
        "currency": "JPY"
      },
      "expected": {
        "should_succeed": true,
        "itinerary_count": 5
      }
    },

    {
      "id": "test-010-invalid-duration-zero",
      "name": "无效参数 - 时长为0",
      "description": "测试无效的 duration 参数（应返回错误）",
      "request": {
        "cityId": "test",
        "cityName": "Test City",
        "cityImage": "https://example.com/test.jpg",
        "duration": 0,
        "budget": "medium",
        "travelStyle": "culture",
        "interests": ["test"]
      },
      "expected": {
        "should_succeed": false,
        "error_message": "duration must be between 1 and 30"
      }
    },

    {
      "id": "test-011-invalid-duration-exceed",
      "name": "无效参数 - 时长超过30天",
      "description": "测试超出最大时长限制（应返回错误）",
      "request": {
        "cityId": "test",
        "cityName": "Test City",
        "cityImage": "https://example.com/test.jpg",
        "duration": 31,
        "budget": "medium",
        "travelStyle": "culture",
        "interests": ["test"]
      },
      "expected": {
        "should_succeed": false,
        "error_message": "duration must be between 1 and 30"
      }
    },

    {
      "id": "test-012-missing-required",
      "name": "无效参数 - 缺少必填字段",
      "description": "测试缺少必填字段（cityId, cityName等）",
      "request": {
        "duration": 3,
        "budget": "medium",
        "travelStyle": "culture",
        "interests": ["test"]
      },
      "expected": {
        "should_succeed": false,
        "error_message": "missing required fields"
      }
    }
  ]
}
